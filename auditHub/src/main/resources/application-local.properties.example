# ================================================================
# application-local.properties.example
# Bu dosyayi kopyalayip "application-local.properties" olarak kaydet.
# Sonra JIRA_PAT satirina kendi tokenini yaz.
# application-local.properties dosyasi Git'e gitmez (.gitignore).
# ================================================================
#
# Token nasil olusturulur:
# 1. https://jira.thy.com adresine giris yap
# 2. Sag ust profil menusu -> Profile -> Personal Access Tokens
# 3. Create Token -> isim ver -> olustur
# 4. Tokeni kopyala (bir daha gosterilmez!)
#
jira.base-url=https://jira.thy.com
#jira.personal-access-token=BURAYA_KENDI_TOKENINI_YAZ
